<Window x:Class="LegacyEditor.Views.WipeCompleteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wipe Complete"
        Width="420" Height="480" MinWidth="360" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource BgBaseBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Wipe Complete" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="&#x2716;" Width="28" Height="28"
                            FontSize="12" Padding="0" BorderThickness="0"
                            Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                            Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="20,16,20,12" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Total removed -->
                    <Border Background="{DynamicResource BgSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                            Padding="16,14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Entities Removed" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TotalRemovedText" FontSize="36" FontWeight="Light"
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="ChunksScannedText" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Dimensions -->
                    <Border Background="{DynamicResource BgSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                            Padding="16,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="By Dimension" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="DimOverworld" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="DimNether" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="DimEnd" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Top entities -->
                    <Border Background="{DynamicResource BgSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                            Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="Top Entities Removed" Style="{StaticResource SectionTitle}"/>
                            <ItemsControl x:Name="TopEntitiesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Count}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom bar -->
            <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="16,10">
                <Button Content="OK" Style="{StaticResource PrimaryButton}"
                        Width="80" Height="32" HorizontalAlignment="Right"
                        Click="OkBtn_Click" IsDefault="True"/>
            </Border>
        </Grid>
    </Border>
</Window>
